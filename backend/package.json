{
  "name": "smart-irrigation-backend",
  "version": "0.1.0",
  "description": "IoT-Based Smart Irrigation System — backend API",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "db:init": "node src/scripts/initDb.js",
    "db:ping": "node src/scripts/pingDb.js",
    "db:seed:admin": "node src/scripts/seedAdmin.js",
    "db:seed:demo": "node src/scripts/seedDemo.js",
    "db:demo:reset": "node src/scripts/initDb.js && node src/scripts/seedAdmin.js && node src/scripts/seedDemo.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "mysql2": "^3.11.0",
    "pdfkit": "^0.15.0"
  }
}
