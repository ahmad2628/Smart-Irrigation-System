{
  "name": "smart-irrigation-serial-bridge",
  "version": "0.1.0",
  "description": "Reads JSON readings from an Arduino over USB serial and forwards them to the backend API.",
  "type": "module",
  "main": "bridge.js",
  "scripts": {
    "start": "node bridge.js",
    "list-ports": "node -e \"import('serialport').then(m=>m.SerialPort.list().then(p=>console.log(p)))\""
  },
  "dependencies": {
    "serialport": "^12.0.0",
    "@serialport/parser-readline": "^12.0.0"
  }
}
